{
  "name": "wx-mcp",
  "version": "1.4.8",
  "description": "Agent-first MCP server for local WeChat 4.x data.",
  "homepage": "https://github.com/r266-tech/wx-mcp",
  "license": "MIT",
  "platforms": ["darwin-arm64", "windows-amd64"],
  "transport": {
    "type": "stdio",
    "command": "./wx-mcp"
  },
  "installer": {
    "command": "./install.sh --all --yes --json",
    "doctor": "./install.sh --doctor --json",
    "update": "./install.sh --update --yes --json",
    "windowsCommand": ".\\install.ps1 --all --yes --json",
    "windowsDoctor": ".\\install.ps1 --doctor --json"
  },
  "runtime": {
    "requires": [
      "WeChat 4.x local data directory",
      "libWCDB.dylib/libWCDB.dll beside wx-mcp or configured with WX_MCP_WCDB_LIB",
      "schema-2 WeChat DB key map in ~/.config/wxcli/config.json",
      "macOS can use wxkey bootstrap; Windows requires an existing schema-2 key map"
    ],
    "keyBootstrap": "./wxkey bootstrap"
  },
  "tools": {
    "primary": ["sessions", "resolve_chat", "messages", "media_resources", "search", "new_messages"],
    "cache": ["cache_status", "cache_refresh", "cache_rebuild", "unread", "stats", "export_messages"],
    "payments": ["transfers", "red_packets"],
    "social": ["sns", "sns_feed", "sns_search", "sns_notifications"],
    "diagnostic": ["schema", "sql"]
  }
}
