{
  "name": "wechat-cli",
  "version": "1.6.1",
  "description": "CLI-first local WeChat 4.x data reader for macOS and Windows, with an optional legacy MCP stdio adapter.",
  "homepage": "https://github.com/r266-tech/wechat-local-mcp",
  "license": "MIT",
  "platforms": ["darwin-arm64", "windows-amd64"],
  "transport": {
    "type": "stdio",
    "command": "./wechat-cli",
    "args": ["serve-mcp"],
    "windowsCommand": ".\\wechat-cli.exe",
    "windowsArgs": ["serve-mcp"]
  },
  "installer": {
    "oneLineMacOS": "curl -fsSL https://raw.githubusercontent.com/r266-tech/wechat-local-mcp/main/scripts/install-release.sh | zsh",
    "oneLineMacOSJson": "curl -fsSL https://raw.githubusercontent.com/r266-tech/wechat-local-mcp/main/scripts/install-release.sh | env WECHAT_CLI_INSTALL_JSON=1 zsh",
    "oneLineWindows": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"irm https://raw.githubusercontent.com/r266-tech/wechat-local-mcp/main/scripts/install-release.ps1 | iex\"",
    "oneLineWindowsJson": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"[Environment]::SetEnvironmentVariable('WECHAT_CLI_INSTALL_JSON','1','Process'); irm https://raw.githubusercontent.com/r266-tech/wechat-local-mcp/main/scripts/install-release.ps1 | iex\"",
    "command": "./install.sh --all --yes --json",
    "doctor": "./install.sh --doctor --json",
    "update": "./install.sh --update --yes --json",
    "windowsCommand": ".\\install.ps1 -All -Yes -Json",
    "windowsDoctor": ".\\install.ps1 -Doctor -Json",
    "windowsDryRun": ".\\install.ps1 -DryRun -All -Json",
    "windowsUpdate": ".\\install.ps1 -Update -Yes -Json"
  },
  "runtime": {
    "requires": [
      "WeChat 4.x local data directory for the current OS user",
      "macOS release zip includes wechat-cli, wxkey, libWCDB.dylib, install.sh, README.md, llms.txt, AGENTS.md, mcp-server.json, and scripts/install-release.sh",
      "Windows release zip includes wechat-cli.exe, libWCDB.dll, install.ps1, README.md, llms.txt, AGENTS.md, mcp-server.json, and scripts/install-release.ps1",
      "schema-2 WeChat DB key map is created by macOS wxkey bootstrap or Windows process scan",
      "macOS key setup uses wxkey bootstrap; Windows key setup scans a running Weixin.exe/WeChat.exe process and stores verified schema-2 keys"
    ],
    "keyBootstrap": "./wxkey bootstrap",
    "windowsKeySetup": ".\\wechat-cli.exe cache refresh --force"
  },
  "tools": {
    "primary": ["sessions", "resolve_chat", "chat_timeline", "messages", "media_resources", "search"],
    "cache": ["cache_status", "cache_refresh", "cache_rebuild", "unread", "stats", "export_messages"],
    "payments": ["transfers", "red_packets"],
    "social": ["sns", "sns_feed", "sns_search", "sns_notifications"],
    "contacts": ["contacts", "group_members"],
    "content": ["favorites", "chatroom_announcements", "forward_history"],
    "diagnostic": ["schema", "sql"]
  }
}
